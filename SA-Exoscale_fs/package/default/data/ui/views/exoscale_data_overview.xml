        "ds_6U6ySlQS_ds_sRZag8F1_ds_i4wRou6J_ds_vy1Z66iY": {
            "name": "most_performed_action",
            "options": {
                "query": "index=exoscale sourcetype=exoscale:audittrail:mutation user IN ($user_tok$)\n| stats c by action command\n| eval action_activity = action . \" - \" . command\n| sort - c\n| head 1\n| table action_activity"
            },
            "type": "ds.search"
        },
        "ds_OkI2RULe_ds_lEKCFHkq": {
            "name": "users_pie_single",
            "options": {
                "query": "index=exoscale user IN ($user_tok$)\n| stats count by handler\n| head limit=10000 ($user_tok|s$ != \"*\")",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            },
            "type": "ds.search"
        },
        "ds_P7cfVenx": {
