        "ds_WKjqrx8F_ds_qpMHhdG5": {
            "name": "user_details_mutation",
            "options": {
                "query": "index=exoscale sourcetype=exoscale:audittrail:mutation user IN ($user_tok$)\n| stats latest(_time) as latest_time c by user action command status\n| convert ctime(latest_time) as latest_time",
                "queryParameters": {
                    "earliest": "$global_time.earliest$",
                    "latest": "$global_time.latest$"
                }
            },
